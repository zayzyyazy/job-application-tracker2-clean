# Copy to `.env` for local development (see README).

# SQLite — Prisma connection string. Local dev default:
DATABASE_URL="file:./dev.db"

# Or set an absolute path (e.g. production with explicit URL):
# DATABASE_URL="file:/data/app.db"

# OpenAI — Discover (web search) and job AI analysis. Optional; Discover falls back without it.
OPENAI_API_KEY=

# Railway: optional filename when the DB lives on a mounted volume (see README).
# Defaults to app.db next to RAILWAY_VOLUME_MOUNT_PATH / SQLITE_DATA_DIR.
# SQLITE_DATABASE_NAME=app.db
