{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Job Application Tracker",
  "version": "0.1.0",
  "identifier": "com.jobapplicationtracker.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev:tauri",
    "beforeBuildCommand": "npm run build && npm run tauri:prepare-bundle"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Job Application Tracker",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "create": false,
        "url": "http://127.0.0.1:14587"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [],
    "resources": {
      "resources/next-server": "next-server"
    }
  }
}
